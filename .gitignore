# Python bytecode cache (anywhere in the tree: shared/python/, tests/, ...)
__pycache__/
*.pyc

# pytest cache
.pytest_cache/

# Claude Code developer tooling — local machine state, not distributed
.claudeignore
AGENTS.md
CLAUDE.md

# Sync registry — local machine state, not canonical
sync-registry.json

# pip build artifacts
*.egg-info/
build/
dist/
node_modules/

# Audit tooling output — not part of the repository
audit.manifest.yml

# Internal management — work history, developer tooling, monorepo governance
archive/
common/
docs/governance/
docs/publication/
docs/AI_AGENT_RUNTIME_TOKEN_OPTIMIZATION.md
workspace/

# coverage output
.coverage
.coverage.*
htmlcov/
coverage.xml

# this canonical repo does not track its own root adoption records
# (root-only: a tracked worked example under examples/**/.adop/ is allowed)
/.adop/

# secrets / credentials — never commit
.env
.env.*
*.env
secrets/
keys/
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*credentials*.json
